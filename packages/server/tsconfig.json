{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@snap-grid/shared": ["../shared/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": ["src", "../shared/src"]
}
